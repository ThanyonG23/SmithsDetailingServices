# ===========================================================
#  SMITHS DETAILING — ENVIRONMENT VARIABLES
#  Copy this file to ".env.local" and fill in the values.
#  NEVER commit .env.local (it's already in .gitignore).
# ===========================================================

# --- Supabase (Project Settings → API) ---
# The "Project URL"
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The "service_role" secret key — SERVER ONLY, keep it secret!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend email (https://resend.com → API Keys) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Who emails are sent FROM. Until you verify your domain in Resend,
# you can use: Smiths Detailing <onboarding@resend.dev>
EMAIL_FROM=Smiths Detailing <bookings@smithsdetailingservices.com.au>
# Where the "new booking" notification goes (you)
OWNER_EMAIL=info@smithsdetailingservices.com.au

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://smithsdetailingservices.com.au
